DATABASE_URL=postgresql://logistisy:logistisy@db:5432/logistisy
REDIS_URL=redis://redis:6379/0

# Local LLM via Ollama — GPU-accelerated, no API key, no cloud cost
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_TEXT_MODEL=llama3.1

# Since you have a GPU: for higher OCR/extraction accuracy (~75% vs
# llama3.2-vision benchmarked lower), swap to:
# OLLAMA_VISION_MODEL=qwen2.5-vl
# (pull it first: docker compose exec ollama ollama pull qwen2.5-vl)

ENVIRONMENT=development
